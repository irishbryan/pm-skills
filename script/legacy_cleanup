#!/usr/bin/env bash
set -euo pipefail

LEGACY_PROFILE="$HOME/.claude/pm-claude-skills.local.md"
CLAUDE_SKILLS_TARGET="$HOME/.claude/skills"
HAS_CLAUDE="false"
LEGACY_PLUGIN_INSTALLED="false"

LEGACY_SKILLS=(
  "my-status"
  "team-status"
  "meeting-digest"
  "slack-recap"
  "shape-product-pitch"
)

usage() {
  cat <<'EOF'
Usage: script/legacy_cleanup

Remove legacy artifacts left behind by older versions of this repo.

This script is intentionally conservative:
- It only targets repo-specific legacy artifacts from older installs
- It asks for confirmation before removing anything
- It is meant to be run once, only when upgrading an older install

Legacy artifacts this script may remove:
- old Claude plugin registration for `pm-claude-skills`
- old Claude marketplace entry for `pm-claude-skills`
- old Claude profile at `~/.claude/pm-claude-skills.local.md`
- old Claude skill symlinks at `~/.claude/skills/pm-skills-*`

It does not remove current pm-skills installs, Codex installs, or third-party integrations.
EOF
}

if [ "${1:-}" = "-h" ] || [ "${1:-}" = "--help" ]; then
  usage
  exit 0
elif [ -n "${1:-}" ]; then
  usage >&2
  exit 1
fi

print_section() { echo "" && echo "$1"; }
print_result() { echo "$1: $2"; }

skill_symlink_path() {
  printf '%s/pm-skills-%s' "$CLAUDE_SKILLS_TARGET" "$1"
}

skill_symlink_owned() {
  local skill="$1"
  local path
  local target

  path="$(skill_symlink_path "$skill")"
  [ -L "$path" ] || return 1

  target="$(readlink "$path")"
  case "$target" in
    */plugins/pm-skills/skills/"$skill") return 0 ;;
    */plugins/pm-claude-skills/skills/"$skill") return 0 ;;
    *) return 1 ;;
  esac
}

detect_legacy_plugin() {
  if ! command -v claude >/dev/null 2>&1; then
    return
  fi

  HAS_CLAUDE="true"
  if claude plugin list 2>/dev/null | grep -q "^pm-claude-skills "; then
    LEGACY_PLUGIN_INSTALLED="true"
  fi
}

detect_legacy_artifacts() {
  local found="false"
  local skill

  print_section "Detected"

  detect_legacy_plugin
  if [ "$LEGACY_PLUGIN_INSTALLED" = "true" ]; then
    print_result "Legacy Claude plugin" "pm-claude-skills"
    found="true"
  else
    print_result "Legacy Claude plugin" "not found"
  fi

  if [ -f "$LEGACY_PROFILE" ]; then
    print_result "Legacy profile" "$LEGACY_PROFILE"
    found="true"
  else
    print_result "Legacy profile" "not found"
  fi

  for skill in "${LEGACY_SKILLS[@]}"; do
    if skill_symlink_owned "$skill"; then
      print_result "Legacy Claude skill symlink" "$(skill_symlink_path "$skill")"
      found="true"
    fi
  done

  if [ "$found" != "true" ]; then
    print_result "Status" "no legacy repo-specific artifacts found"
  fi

  FOUND_LEGACY="$found"
}

remove_legacy_plugin() {
  [ "$LEGACY_PLUGIN_INSTALLED" = "true" ] || return 0
  claude plugin uninstall pm-claude-skills >/dev/null 2>&1 || true
  claude plugin marketplace remove pm-claude-skills >/dev/null 2>&1 || true
  print_result "Removed" "legacy Claude plugin and marketplace entry"
}

remove_legacy_skill_symlinks() {
  local skill
  local path

  for skill in "${LEGACY_SKILLS[@]}"; do
    if skill_symlink_owned "$skill"; then
      path="$(skill_symlink_path "$skill")"
      rm "$path"
      print_result "Removed" "$path"
    fi
  done
}

remove_legacy_profile() {
  [ -f "$LEGACY_PROFILE" ] || return 0

  read -rp "Delete legacy profile at $LEGACY_PROFILE? [y/N]: " DELETE_LEGACY_PROFILE
  if [[ "$DELETE_LEGACY_PROFILE" =~ ^[Yy] ]]; then
    rm "$LEGACY_PROFILE"
    print_result "Removed" "$LEGACY_PROFILE"
  else
    print_result "Kept" "$LEGACY_PROFILE"
  fi
}

echo ""
echo "pm-skills legacy cleanup"
echo "This is a one-time cleanup for older installs of this repo."

detect_legacy_artifacts

if [ "${FOUND_LEGACY:-false}" != "true" ]; then
  print_section "Done"
  print_result "Cleanup" "not needed"
  echo ""
  exit 0
fi

print_section "Cleanup"
echo "This will remove only legacy artifacts from older pm-skills installs."
echo "Current pm-skills installs and third-party integrations will be left alone."
echo ""
read -rp "Continue? [y/N]: " CONFIRM
if [[ ! "$CONFIRM" =~ ^[Yy] ]]; then
  print_result "Skipped" "no changes made"
  echo ""
  exit 0
fi

if [ "$HAS_CLAUDE" = "true" ]; then
  remove_legacy_plugin
else
  print_result "Skipped" "claude CLI not found; cannot check or remove legacy plugin"
fi

remove_legacy_skill_symlinks
remove_legacy_profile

print_section "Done"
print_result "Cleanup" "completed"
print_result "Use" "run this script only once when upgrading an older install"
echo ""
